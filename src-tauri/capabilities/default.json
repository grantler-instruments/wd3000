{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "osc-midi-default",
    "sensors-default",
    "sensors:default",
    "sensors:allow-start-watch",
    "sensors:allow-stop-watch",
    "sensors:allow-list-sensors"
  ]
}

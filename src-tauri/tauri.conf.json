{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WD3000",
  "version": "0.0.1",
  "identifier": "com.grantler-instruments.wd3000",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "WD3000",
        "width": 1100,
        "height": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "iOS": {
      "developmentTeam": "6QBJR6369U",
      "frameworks": [
        "CoreMIDI"
      ]
    }
  }
}

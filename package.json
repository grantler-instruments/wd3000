{
  "name": "wd3000",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:pages": "cross-env VITE_BASE=/wd3000/ npm run build --prefix website && cross-env VITE_BASE=/wd3000/app/ npm run build && node scripts/assemble-pages.mjs",
    "preview": "vite preview",
    "preview:pages": "vite preview --outDir site --base /wd3000/",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "cross-env PLAYWRIGHT_BROWSERS_PATH=0 playwright test",
    "test:e2e:smoke": "cross-env PLAYWRIGHT_BROWSERS_PATH=0 playwright test --project=smoke",
    "test:e2e:install": "cross-env PLAYWRIGHT_BROWSERS_PATH=0 playwright install chromium",
    "tauri": "tauri",
    "tauri:ios": "tauri ios dev \"iPhone 17\"",
    "tauri:ios:device": "tauri ios dev --host",
    "tauri:ios:sync-export-options": "cp src-tauri/ExportOptions.ios.plist src-tauri/gen/apple/ExportOptions.plist",
    "tauri:ios:bundle": "npm run tauri:ios:sync-export-options && tauri ios build --debug --open --export-method debugging",
    "tauri:ios:build": "npm run tauri:ios:sync-export-options && tauri ios build -- --export-method app-store-connect",
    "tauri:ios:open-archive": "open src-tauri/gen/apple/build/wd3000_iOS.xcarchive",
    "tauri:android": "tauri android dev",
    "website:dev": "npm run dev --prefix website",
    "website:build": "npm run build --prefix website",
    "website:preview": "npm run preview --prefix website",
    "version:sync": "node scripts/sync-version.mjs",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*": "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@grantler-instruments/mui-theme": "^0.0.3",
    "@mediapipe/camera_utils": "^0.3.1675466862",
    "@mediapipe/drawing_utils": "^0.3.1675466124",
    "@mediapipe/hands": "^0.4.1675469240",
    "@mediapipe/pose": "^0.5.1675469404",
    "@mui/icons-material": "^9.2.0",
    "@mui/material": "^9.2.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "i18next": "^26.3.6",
    "lodash.throttle": "^4.1.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^17.0.10",
    "react-webcam": "^7.2.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@playwright/test": "^1.60.0",
    "@tauri-apps/cli": "^2",
    "@types/lodash.throttle": "^4.1.9",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/coverage-v8": "^3.2.6",
    "cross-env": "^10.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^3.2.4"
  }
}
